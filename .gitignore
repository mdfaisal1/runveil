# -----------------------------------------
# RUNVEIL PROJECT .gitignore
# (Go + Rust + Node + Docker + VSCode)
# -----------------------------------------

# ==== Go ====
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
*.coverprofile
profile.cov
go.work
go.work.sum

# ==== Rust ====
# Ignore Rust build directory
/target/
**/target/

# Rust/Cargo files to keep:
!Cargo.toml
!Cargo.lock

# ==== Node / npm ====
node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log

# npm lock files you want to ignore individually if not needed:
# package-lock.json
# yarn.lock

# ==== Docker ====
*.pid

# ==== VSCode ====
.vscode/
.history/

# ==== Logs ====
*.log

# ==== Environment Files ====
.env
.env.local
.env.*.local

# ==== OS / System Noise ====
.DS_Store
Thumbs.db

# ==== Binary outputs ====
*.pdb
*.dSYM/
*.pdb
*.dll
*.bin
*.run
*.exe~
*.lock


# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example

# Local Claude Code state
.claude/
